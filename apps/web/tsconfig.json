{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "lib": ["DOM", "ESNext"],
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@domains/*": ["./src/domains/*"],
      "@app/*": ["./src/app/*"],
    },
  },
  "include": ["src", "@types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"],
}
