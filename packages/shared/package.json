{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "lint": "eslint src/ --fix --ext .ts"
  },
  "exports": {
    "./stylesheets/*.css": "./src/stylesheets/*.css",
    "./anim": {
      "types": "./src/lib/anim.ts",
      "default": "./dist/lib/anim.js"
    },
    "./clock": {
      "types": "./src/lib/clock.ts",
      "default": "./dist/lib/clock.js"
    },
    "./dom": {
      "types": "./src/lib/dom.ts",
      "default": "./dist/lib/dom.js"
    }
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "@typescript/native-preview": "7.0.0-dev.20260223.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*"
  }
}
