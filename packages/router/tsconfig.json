{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2018", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "declaration": true,
    "verbatimModuleSyntax": true,
  },
  "include": ["src/index.ts"],
  "exclude": ["node_modules", "dist"],
}
